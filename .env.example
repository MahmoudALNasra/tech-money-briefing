NEXT_PUBLIC_SITE_URL=https://techrevenuebrief.com
NEXT_PUBLIC_SITE_NAME=Tech Revenue Brief
NEXT_PUBLIC_GTM_ID=GTM-K3XRLKRF

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# OAuth apps (GitHub, Microsoft, LinkedIn, Google) must register this callback URL:
# https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback
ADMIN_EMAILS=info@techrevenuebrief.com

OPENAI_API_KEY=sk-your-openai-key
YOUTUBE_API_KEY=your-youtube-data-api-key
CRON_SECRET=replace-with-a-long-random-secret
TRACKING_HASH_SECRET=replace-with-a-long-random-secret-for-visitor-hashing
ANALYTICS_DASHBOARD_TOKEN=replace-with-a-long-random-dashboard-token
# Comma-separated public IPs to exclude from first-party analytics and GTM.
ANALYTICS_EXCLUDED_IPS=35.147.75.112

# Business data generator. Keep these server-side only.
GOOGLE_PLACES_API_KEY=your-google-places-server-key
# Optional dedicated server-side key with Google Static Maps API enabled.
GOOGLE_STATIC_MAPS_API_KEY=your-google-static-maps-server-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_BUSINESS_DATA_EXPORT_PRICE_ID=price_your-business-data-export-price
STRIPE_BUSINESS_DATA_STARTER_PRICE_ID=price_your-999-starter-price
STRIPE_BUSINESS_DATA_GROWTH_PRICE_ID=price_your-1999-growth-price
STRIPE_BUSINESS_DATA_AGENCY_PRICE_ID=price_your-5000-agency-price
# Use payment for one-time Stripe prices, subscription for recurring prices.
STRIPE_BUSINESS_DATA_CHECKOUT_MODE=payment
# Optional but recommended: long random secret used to sign paid export cookies.
BUSINESS_DATA_PAID_ACCESS_SECRET=replace-with-a-long-random-secret-for-paid-business-data-access
# Business credits for the data generator (1 credit = 1 processed business)
BUSINESS_DATA_SUBSCRIPTION_TOKENS=150
BUSINESS_DATA_SUBSCRIPTION_PRICE_USD=9.99
NEXT_PUBLIC_BUSINESS_DATA_SUBSCRIPTION_TOKENS=150
NEXT_PUBLIC_BUSINESS_DATA_PRICE=9.99
BUSINESS_DATA_STARTER_PRICE_USD=9.99
BUSINESS_DATA_STARTER_CREDITS=150
BUSINESS_DATA_GROWTH_PRICE_USD=19.99
BUSINESS_DATA_GROWTH_CREDITS=350
BUSINESS_DATA_AGENCY_PRICE_USD=50
BUSINESS_DATA_AGENCY_CREDITS=850
BUSINESS_DATA_FULL_EXPORT_TOKENS=1
BUSINESS_DATA_DRIVE_UPLOAD_TOKENS=0
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
# Live payment email checklist:
# - Use live STRIPE_SECRET_KEY, live price IDs, and the live webhook signing secret.
# - Configure the live webhook endpoint for /api/stripe/webhook and checkout.session.completed.
# - Enable Stripe customer emails/receipts in the Stripe Dashboard for official receipts.
# - Keep RESEND_API_KEY and CONTACT_FROM_EMAIL configured for the app's backup confirmation email.

# Optional Cloudflare Turnstile for search/export bot protection
# Leave unset locally unless you want the widget enabled.
# Placeholder values like "..." are ignored and Turnstile stays disabled.
#
# Local dev options:
# 1) Leave production keys unset locally (Turnstile disabled in dev)
# 2) Use Cloudflare dummy keys (widget works on localhost):
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
# 3) Keep production keys and add localhost in Cloudflare Hostname Management,
# then set:
# NEXT_PUBLIC_TURNSTILE_ALLOW_LOCALHOST=true
#
# Production: use your real Turnstile keys and add your domain in Cloudflare
# Hostname Management (techrevenuebrief.com and www.techrevenuebrief.com).
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
# NEXT_PUBLIC_TURNSTILE_ALLOW_LOCALHOST=

# Google Nearby Search returns up to about 60 paginated places; lower this to control GCP cost.
BUSINESS_DATA_EXPORT_MAX_RESULTS=60
FREE_LIFETIME_RUNS=3
FREE_RUN_ENRICHED_COUNT=3
SAMPLE_ENRICH_SIZE=15
NEXT_PUBLIC_SAMPLE_ENRICH_SIZE=15
ENRICHMENT_CACHE_TTL_DAYS=45

# Optional browser-restricted key for the interactive map only.
# In Google Cloud Console, restrict this key to HTTP referrers such as:
# https://techrevenuebrief.com/*
# https://www.techrevenuebrief.com/*
# http://localhost:3000/*
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=your-google-maps-javascript-browser-key

# Contact form email delivery (Resend)
RESEND_API_KEY=re_your-resend-api-key
CONTACT_FROM_EMAIL=Tech Revenue Brief <info@techrevenuebrief.com>
# Daily /leads social draft emails (defaults to ADMIN_EMAILS when unset)
# SOCIAL_DRAFT_EMAIL=info@techrevenuebrief.com
# Optional model override for social draft generation (separate from article pipeline)
# SOCIAL_DRAFT_MODEL=gpt-4o-mini
# Optional model override for the owner-voice pass on social drafts
# SOCIAL_OWNER_VOICE_MODEL=gpt-4o-mini
# Optional model override for the emoji polish pass on social drafts
# SOCIAL_EMOJI_MODEL=gpt-4o-mini
# Set true to block RSS/trends/editorial cron publishing even if those routes are hit
# DISABLE_AUTO_ARTICLE_PUBLISH=true
CONTACT_TO_EMAIL=sales@techrevenuebrief.com

NEXT_PUBLIC_GOOGLE_AD_CLIENT=ca-pub-8203750015609502
NEXT_PUBLIC_GOOGLE_AD_SLOT_NATIVE=8512522207

# Keep promotional popups off during AdSense review. Inline newsletter,
# referral, and sponsor sections can still render where relevant.
NEXT_PUBLIC_ENABLE_REFERRAL_NUDGE=false
NEXT_PUBLIC_ENABLE_SCROLL_NEWSLETTER=false

# Set true only during a short AdSense content-cleanup window (hides tools from sitemap/robots, throttles publishing).
# Keep false for normal operation, SEO, and GEO. llms.txt is always served either way.
ADSENSE_REVIEW_MODE=false
# Throttle daily publish volume while quality pipeline improves (used when ADSENSE_REVIEW_MODE=true).
ADSENSE_REVIEW_MAX_RSS=2
ADSENSE_REVIEW_MAX_EDITORIAL=1
ADSENSE_REVIEW_MAX_TRENDS=0

NEXT_PUBLIC_PROMO_TITLE=Your ad here
NEXT_PUBLIC_PROMO_DESCRIPTION=Reach operators, founders, and technical buyers reading high-intent industry analysis.
NEXT_PUBLIC_PROMO_CTA=Advertise with us
NEXT_PUBLIC_PROMO_URL=mailto:ads@techrevenuebrief.com
NEXT_PUBLIC_PROMO_BADGE=Partner Slot

# Optional: active paid sponsor (shown on articles, tools, comparisons, and feed)
NEXT_PUBLIC_SPONSOR_ENABLED=false
NEXT_PUBLIC_SPONSOR_BADGE=Sponsored
NEXT_PUBLIC_SPONSOR_TITLE=
NEXT_PUBLIC_SPONSOR_DESCRIPTION=
NEXT_PUBLIC_SPONSOR_CTA=Learn more
NEXT_PUBLIC_SPONSOR_URL=

INGEST_MAX_ITEMS_PER_SOURCE=3
EDITORIAL_MAX_NEW_ARTICLES=3
EDITORIAL_AUTO_TOPIC_GENERATION=true
KEYWORD_RESEARCH_PROVIDER=openai # openai is cheapest; dataforseo enriches OpenAI output with autocomplete when needed
DATAFORSEO_LOGIN=your-dataforseo-login
DATAFORSEO_PASSWORD=your-dataforseo-password
OPENAI_MODEL=gpt-4o-mini

# Optional: powers the live SERP Intent Analyzer tool.
# Get a key from https://serper.dev/ and keep it server-side only.
SERPER_API_KEY=your-serper-api-key
# Optional: lets the private analytics dashboard estimate Serper renewal risk.
# If you only know the purchase date, credits are treated as expiring 6 months later.
SERPER_CREDITS_TOTAL=2500
SERPER_CREDITS_USED_OFFSET=0
SERPER_CREDITS_PURCHASED_AT=2026-06-01
SERPER_CREDITS_EXPIRES_AT=

# Google Search Console
# Use sc-domain:techrevenuebrief.com for a Domain property, or the exact
# URL-prefix property such as https://techrevenuebrief.com/.
GOOGLE_SEARCH_CONSOLE_SITE_URL=sc-domain:techrevenuebrief.com

# Preferred when service account key creation is blocked by org policy.
GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_OAUTH_REFRESH_TOKEN=your-oauth-refresh-token

# Paid business data "Send to my Google Drive" uses Supabase Google OAuth in
# the same browser window. Configure Google as a Supabase auth provider with
# Drive file scope. In Google Cloud, the authorized redirect URI should be the
# Supabase callback URL: https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback.
# In Supabase Auth URL Configuration, set the production Site URL to
# https://techrevenuebrief.com and add https://techrevenuebrief.com/auth/callback
# to Redirect URLs before going live.

# Alternative: service account with Search Console read access on the property.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Optional aliases: GSC_SITE_URL, GSC_CLIENT_EMAIL, GSC_PRIVATE_KEY,
# GSC_OAUTH_CLIENT_ID, GSC_OAUTH_CLIENT_SECRET, GSC_OAUTH_REFRESH_TOKEN
GSC_LOOKBACK_DAYS=90
GSC_MIN_IMPRESSIONS=1
GSC_CREATE_MIN_IMPRESSIONS=1
GSC_MIN_IMPROVE_POSITION=4
GSC_MAX_IMPROVE_POSITION=35
GSC_LOW_CTR_THRESHOLD=0.03
